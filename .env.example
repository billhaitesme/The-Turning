OLLAMA_BASE_URL=http://127.0.0.1:11434
ACTIVE_CHAT_MODEL=dolphin-mixtral:8x7b
# OLLAMA_CHAT_MODEL remains a backwards-compatible alias when ACTIVE_CHAT_MODEL is unset.
OLLAMA_CHAT_MODEL=dolphin-mixtral:8x7b
MODEL_LOCK=true
ALLOW_TOPIC_ROUTING=false
ALLOW_SECONDARY_REWRITE=false
ALLOW_AUTOMATIC_MODEL_FALLBACK=false
AUTOMATIC_MODEL_FALLBACK_MODEL=llama3.1:8b
OLLAMA_REASONING_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_ROUTER_MODEL=gemma3:1b
OLLAMA_EMBED_MODEL=embeddinggemma:latest
NETWORK_MODE=offline
ACTIVE_PERSONALITY_MODE=default
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
