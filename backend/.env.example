OMEGA_BIND_HOST=127.0.0.1
OMEGA_BACKEND_PORT=8001
# Optional: relocate mutable tool runtime state outside the checkout.
# OMEGA_TOOL_DATA_DIR=C:/path/to/omega-runtime/tool-data
TURNING_DB_PATH=omega_arc.db
# Required before Bridge Zero Mobile endpoints will accept requests.
# Generate a long random value; never commit the real token.
MOBILE_AUTH_TOKEN=
RUNTIME_VERSION=0.2.0
REQUIRED_MOBILE_VERSION=0.2.0
MOBILE_API_VERSION=1
CHRONICLE_PATH=bridge/shared/mobile/chronicle.json
MAX_HISTORY_MESSAGES=12
MAX_MEMORY_RESULTS=6

OLLAMA_BASE_URL=http://localhost:11434/api
ACTIVE_CHAT_MODEL=dolphin-mixtral:8x7b
DIRECT_CHAT_MODEL=dolphin-mixtral:8x7b
# OLLAMA_CHAT_MODEL remains a backwards-compatible alias when ACTIVE_CHAT_MODEL is unset.
OLLAMA_CHAT_MODEL=dolphin-mixtral:8x7b
MODEL_LOCK=true
ALLOW_TOPIC_ROUTING=false
ALLOW_SECONDARY_REWRITE=false
ALLOW_AUTOMATIC_MODEL_FALLBACK=false
AUTOMATIC_MODEL_FALLBACK_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=embeddinggemma

ENABLE_WEB_SEARCH=false
WEB_SEARCH_MAX_RESULTS=5
ENABLE_COGNITION_PIPELINE=true
ENABLE_COGNITION_CONTEXT=false
ENABLE_CURIOSITY_SUGGESTIONS=false
ENABLE_REASONING_PIPELINE=true
ENABLE_REASONING_CONTEXT=false
ENABLE_ACTION_RECOMMENDATIONS=true
ENABLE_PLANNING_PIPELINE=true
ENABLE_PLANNING_CONTEXT=false
ENABLE_DECISION_RECORDS=true
ENABLE_AUTOMATIC_PLAN_REVISION=true
ENABLE_DELIBERATION_PIPELINE=true
ENABLE_DELIBERATION_CONTEXT=false
ENABLE_PLAN_EXECUTION=false
ENABLE_TOOL_FRAMEWORK=true
ENABLE_TOOL_EXECUTION=true
ENABLE_TOOL_DRY_RUN=true
ENABLE_CRITICAL_TOOLS=false
ENABLE_BACKEND_HEALTH_CHECK=true
BACKEND_HEALTH_CHECK_TIMEOUT_SECONDS=3
BACKEND_HEALTH_CHECK_PATHS=/health,/system/status,/
TOOL_APPROVAL_TTL_SECONDS=300
