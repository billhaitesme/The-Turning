# The Xcode project is GENERATED by XcodeGen from project.yml, which is the source of
# truth. Committing it would create two competing definitions of the target.
*.xcodeproj/
*.xcworkspace/

# Xcode build state
build/
DerivedData/
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Packaging output (produced by CI for sideloading)
Payload/
*.ipa
*.dSYM.zip

# Signing material must never be committed.
*.mobileprovision
*.p12
*.cer
